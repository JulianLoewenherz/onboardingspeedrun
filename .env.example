# --- Composio + AI (required) ---
COMPOSIO_API_KEY=your_composio_api_key
OPENAI_API_KEY=your_openai_api_key
COMPOSIO_USER_ID=your_composio_user_id

# --- Workspace defaults (used by CLI; overridden by Supabase settings in UI) ---
GITHUB_REPO=owner/repo-name
NOTION_PARENT_PAGE_ID=your_notion_page_id
SLACK_ENABLED=false   # set to true once Slack is connected in app.composio.dev

# --- Supabase (required for the UI backend) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
